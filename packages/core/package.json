{
  "name": "@labelflow-core/engine",
  "version": "0.2.0",
  "description": "Framework-agnostic image annotation engine — draw, select, drag, resize bounding boxes on images with zoom and pan support",
  "author": "samandar_log02",
  "homepage": "https://github.com/Samandar0021305/LabelFlow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Samandar0021305/LabelFlow.git",
    "directory": "packages/core"
  },
  "keywords": [
    "annotation",
    "image-annotation",
    "bounding-box",
    "bbox",
    "canvas",
    "drawing",
    "labeling",
    "image-labeling",
    "object-detection",
    "computer-vision",
    "machine-learning",
    "ml",
    "dataset",
    "image-markup",
    "canvas2d",
    "typescript",
    "framework-agnostic",
    "zoom",
    "pan",
    "resize"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT"
}
