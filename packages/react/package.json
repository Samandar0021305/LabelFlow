{
  "name": "@labelflow-core/react",
  "version": "0.1.3",
  "description": "React image annotation components — draw, select, drag, resize bounding boxes on images with zoom and pan support",
  "author": "samandar_log02",
  "homepage": "https://github.com/samandar-log02/labelflow-core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samandar-log02/labelflow-core.git",
    "directory": "packages/react"
  },
  "keywords": [
    "react",
    "react-annotation",
    "react-image-annotation",
    "react-canvas",
    "react-bounding-box",
    "annotation",
    "image-annotation",
    "bounding-box",
    "bbox",
    "canvas",
    "drawing",
    "labeling",
    "image-labeling",
    "object-detection",
    "computer-vision",
    "machine-learning",
    "ml",
    "dataset",
    "react-component",
    "react-hooks",
    "typescript",
    "zoom",
    "pan",
    "resize",
    "drag"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@labelflow-core/engine": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT"
}
