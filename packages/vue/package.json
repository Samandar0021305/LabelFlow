{
  "name": "@labelflow-core/vue",
  "version": "0.1.3",
  "description": "Vue 3 image annotation components — draw, select, drag, resize bounding boxes on images with zoom and pan support",
  "author": "samandar_log02",
  "homepage": "https://github.com/samandar-log02/labelflow-core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samandar-log02/labelflow-core.git",
    "directory": "packages/vue"
  },
  "keywords": [
    "vue",
    "vue3",
    "vue-annotation",
    "vue-image-annotation",
    "vue-canvas",
    "vue-bounding-box",
    "annotation",
    "image-annotation",
    "bounding-box",
    "bbox",
    "canvas",
    "drawing",
    "labeling",
    "image-labeling",
    "object-detection",
    "computer-vision",
    "machine-learning",
    "ml",
    "dataset",
    "vue-component",
    "composable",
    "typescript",
    "zoom",
    "pan",
    "resize",
    "drag"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@labelflow-core/engine": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT"
}
